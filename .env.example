# =============================================================
# ENVIRONMENT VARIABLES — chatbot-app
# =============================================================
# WARNING: DO NOT COMMIT the actual .env file to git.
# This file (.env.example) is safe to commit — it contains only
# placeholder values. Copy it to .env and fill in your secrets.
#   cp .env.example .env
# =============================================================

# Google AI Studio API key.
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# Gemini model name to use.
# Example values: gemini-2.5-flash, gemini-1.5-pro
GEMINI_LLM_MODEL=gemini-2.5-flash
