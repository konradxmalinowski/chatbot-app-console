# =============================================================
# ENVIRONMENT VARIABLES — chatbot-app
# =============================================================
# WARNING: DO NOT COMMIT the actual .env file to git.
# This file (.env.example) is safe to commit — it contains only
# placeholder values. Copy it to .env and fill in your secrets.
#   cp .env.example .env
# =============================================================

# Chat model provider (CLI --llm-provider flag / API startup). Valid values:
# gemini, openai, anthropic, ollama. Default when unset: gemini (unchanged
# pre-existing behavior). Each provider requires its own key/service below —
# only the active provider's requirement is validated at startup.
LLM_PROVIDER=gemini

# Google AI Studio API key. Required when LLM_PROVIDER=gemini (the default).
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# Gemini model name to use. Required when LLM_PROVIDER=gemini, unless --model
# is passed on the command line.
# Example values: gemini-2.5-flash, gemini-1.5-pro
GEMINI_LLM_MODEL=gemini-2.5-flash

# Embeddings provider for the RAG pipeline (--rag flag). Valid values: ollama, openai.
# Default when unset: ollama (runs locally, no cloud key needed — requires Ollama
# running with `ollama pull nomic-embed-text`).
EMBEDDINGS_PROVIDER=ollama

# OpenAI API key. Required when EMBEDDINGS_PROVIDER=openai, and also when
# LLM_PROVIDER=openai (the same key covers both chat completions and embeddings).
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API key. Only required when LLM_PROVIDER=anthropic.
# Obtain from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- REST API (Phase 3, api/main.py — run with `uvicorn api.main:app`) ---

# Pre-shared secret required to obtain a JWT via POST /auth/token.
# Generate with: openssl rand -hex 32
API_SECRET=your_api_secret_here

# Signs JWTs issued by POST /auth/token (HS256). Must differ from API_SECRET.
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here

# Comma-separated list of allowed CORS origins for the REST API.
# Example: https://example.com,https://app.example.com
# Empty/unset (default) = no origin is allowed (fail closed, never "*").
CORS_ORIGINS=
